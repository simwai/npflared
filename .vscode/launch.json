{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API attach 8787",
      "type": "node",
      "request": "attach",
      "address": "127.0.0.1",
      "port": 9229,
      "preLaunchTask": "API dev 8787",
      "skipFiles": [
        "<node_internals>/**",
        "**/node_modules/**"
      ],
      "sourceMaps": true,
      "resolveSourceMapLocations": null,
      "attachExistingChildren": false,
      "autoAttachChildProcesses": false
    },
    {
      "name": "API attach 8788",
      "type": "node",
      "request": "attach",
      "address": "127.0.0.1",
      "port": 9230,
      "preLaunchTask": "API dev 8788",
      "skipFiles": [
        "<node_internals>/**",
        "**/node_modules/**"
      ],
      "sourceMaps": true,
      "resolveSourceMapLocations": null,
      "attachExistingChildren": false,
      "autoAttachChildProcesses": false
    },
    {
      "name": "CLI test --local (port 8787)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--import",
        "tsx",
        "--inspect"
      ],
      "args": [
        "./src/index.ts",
        "test",
        "--local",
        "--port",
        "8787"
      ],
      "cwd": "${workspaceFolder}/apps/cli",
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**",
        "**/node_modules/**"
      ],
      "sourceMaps": true,
      "resolveSourceMapLocations": null,
      "env": {
        "NODE_ENV": "development"
      },
      "autoAttachChildProcesses": true
    },
    {
      "name": "CLI test --local (port 8788)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--import",
        "tsx",
        "--inspect"
      ],
      "args": [
        "./src/index.ts",
        "test",
        "--local",
        "--port",
        "8788"
      ],
      "cwd": "${workspaceFolder}/apps/cli",
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**",
        "**/node_modules/**"
      ],
      "sourceMaps": true,
      "resolveSourceMapLocations": null,
      "env": {
        "NODE_ENV": "development"
      },
