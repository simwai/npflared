{
  "name": "npflared",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "dotenv -e .env -- turbo dev",
    "format": "biome format --write",
    "knip": "knip",
    "sherif": "sherif",
    "quality": "dotenv -e .env -- turbo run knip sherif check-format check-types test:single",
    "check-format": "biome check",
    "check-types": "dotenv -e .env -- turbo check-types",
    "test:watch": "dotenv -e .env -- turbo test:watch",
    "test:single": "dotenv -e .env -- turbo test:single",
    "smoke-test": "pnpm --filter @npflared/api run test:single"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@changesets/cli": "^2.29.8",
    "knip": "^5.80.2",
    "sherif": "^1.9.0",
    "turbo": "^2.7.4",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*"
  ]
}