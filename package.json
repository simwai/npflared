{
  "name": "npflared",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "build": "turbo build",
    "dev": "dotenv -e .env -- turbo dev",
    "format": "biome format --write",
    "knip": "knip",
    "sherif": "sherif",
    "quality": "turbo run knip sherif check-format check-types test:single",
    "check-format": "biome check",
    "check-types": "turbo check-types",
    "test:watch": "turbo test:watch",
    "test:single": "turbo test:single",
    "smoke-test": "pnpm --filter @npflared/api run test:single",
    "lint-staged": "lint-staged"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@changesets/cli": "^2.29.8",
    "husky": "^9.1.7",
    "knip": "^5.80.2",
    "lint-staged": "^16.4.0",
    "sherif": "^1.9.0",
    "turbo": "^2.7.4",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*"
  ],
  "dependencies": {
    "dotenv": "^17.4.0"
  }
}
